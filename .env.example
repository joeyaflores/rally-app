# Rally — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── Auth ───
BETTER_AUTH_SECRET=           # generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
ALLOWED_EMAILS=you@gmail.com  # comma-separated Google accounts with dashboard access

# ─── Google OAuth ───
# Create at console.cloud.google.com → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Apify (optional) ───
# Social media scraping — sign up at apify.com
APIFY_TOKEN=

# ─── Sentry (optional) ───
# Error tracking — sign up at sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Production URL (optional) ───
# Set this to your deployed URL (used for OG images, share links, etc.)
# NEXT_PUBLIC_URL=https://your-app.fly.dev
